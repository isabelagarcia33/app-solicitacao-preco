/**
 * Cria o menu personalizado na planilha ao abri-la.
 */
function onOpen() {
  SpreadsheetApp.getUi()
    .createMenu(CONFIG.MENU_NAME)
    .addItem("Enviar e-mails para CV", "enviarEmailsCV")
    .addItem("Enviar e-mails para LB", "enviarEmailsLB")
    .addToUi();
}
